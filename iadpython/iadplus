# ---------------------------------------------------------------------------
# Notebook helpers
# ---------------------------------------------------------------------------

def append_graph_cell(nb, header, graph):
    """Append a markdown cell embedding *graph* as a centred image."""
    url = urllib.parse.quote(graph)
    cell_text = '%s\n<center>\n    <img src="%s" width="80%%" />\n</center>\n' % (header, url)
    nb.cells.append(new_markdown_cell(cell_text))


def append_file_cell(nb, header, file):
    """Append a code cell that prints the contents of *file*."""
    base = os.path.basename(file)
    cell_text = (
        '%s\n'
        'with open("%s", "r", encoding="utf-8") as file:\n'
        '    file_contents = file.read()\n'
        '\n'
        'print(file_contents)\n'
    ) % (header, base)
    nb.cells.append(new_code_cell(cell_text))


def append_header(nb, rxt_path):
    """Append the analysis header markdown cell to *nb*."""
    today = datetime.today().strftime('%d %b %Y')
    cell_text = (
        '# Inverse Adding-Doubling Analysis\n\n'
        'iadpython version %s\n\n'
        'This analysis was done on %s\n\n'
        'Input file: `%s`\n'
    ) % (iadpython.__version__, today, os.path.basename(rxt_path))
    nb.cells.append(new_markdown_cell(cell_text))


# ---------------------------------------------------------------------------
# Directory helpers
# ---------------------------------------------------------------------------

def create_notebook_directory(input_name, directory, subdirectory):
    """Create a notebook directory and copy the .rxt file into it.

    Returns (base, base_path) or ('', '') on failure.
    """
    if not os.path.exists(input_name):
        if not input_name.endswith('.rxt'):
            input_name += '.rxt'
        if not os.path.exists(input_name):
            print('input file "%s" not found' % input_name)
            return '', ''

    local_dir = os.path.dirname(input_name)
    base = os.path.splitext(os.path.basename(input_name))[0]

    if subdirectory is None:
        if directory is None:
            notebook_dir = os.path.join(local_dir, base + '-notebook')
        else:
            notebook_dir = os.path.join(local_dir, directory)
            if os.path.exists(notebook_dir) and os.path.isfile(notebook_dir):
                print("Sorry, but '%s' is an existing file!" % notebook_dir)
                print('Use a new or existing directory with --dir option.')
                sys.exit(1)
    else:
        notebook_dir = os.path.join(subdirectory, base)

    os.makedirs(notebook_dir, exist_ok=True)
    shutil.copy(input_name, notebook_dir)

    return base, os.path.join(notebook_dir, base)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    """Entry point."""
    desc = (
        'Invert one or more IAD experiment files (.rxt) using iadpython and '
        'produce a self-contained Jupyter notebook for each one.  The notebook '
        'contains SVG plots of the measured and fitted reflectance/transmittance, '
        'the derived optical properties (mua, mus\', g, mus, a, b), and a grid '
        'diagram showing where the solution sits in the M_R-M_T plane.'
    )
    epilog = (
        'Output layout (default, one file):\n'
        '  sample-notebook/\n'
        '    sample.rxt        copy of the input\n'
        '    sample.txt        cached inversion results (written by iadp)\n'
        '    sample-R.svg      reflectance plot\n'
        '    sample-T.svg      transmittance plot\n'
        '    sample-mua.svg    absorption coefficient\n'
        '    sample-musp.svg   reduced scattering coefficient\n'
        '    sample-grid.svg   M_R vs M_T solution grid\n'
        '    sample.ipynb      Jupyter notebook\n'
        '\n'
        'Examples:\n'
        '  iadplus tissue.rxt\n'
        '  iadplus --force --fit *.rxt\n'
        '  iadplus --options="-q 16" tissue.rxt\n'
        '  iadplus --sdir results/ sample1.rxt sample2.rxt\n'
        '    -> results/sample1/sample1.ipynb\n'
        '    -> results/sample2/sample2.ipynb\n'
        '  iadsum results/   # summarise all of the above\n'
    )
    parser = argparse.ArgumentParser(
        description=desc,
        epilog=epilog,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        'input_files', nargs='+', metavar='FILE.rxt',
        help='IAD experiment file(s) to invert; the .rxt extension may be omitted',
    )
    parser.add_argument(
        '--dir', metavar='DIR', default=None,
        help=(
            'store all output for a single input file in DIR (relative to the '
            '.rxt file location); cannot be used with more than one input file '
            'unless each file shares the same directory'
        ),
    )
    parser.add_argument(
        '--sdir', metavar='SDIR', default=None,
        help=(
            'batch mode: place each sample in its own SDIR/<base>/ subdirectory '
            '(useful when processing many files to keep outputs organised and '
            'compatible with iadsum)'
        ),
    )
    parser.add_argument(
        '--force', action='store_true',
        help='re-run the inversion even if a cached .txt already exists',
    )
    parser.add_argument(
        '--fit', action='store_true',
        help=(
            'overlay a power-law fit  a*(lam_nm/1000)^(-b)  on the scattering '
            'coefficient plots (requires wavelength data above 300 nm)'
        ),
    )
    parser.add_argument(
        '--options', metavar='OPTIONS', default=None,
        help=(
            'extra options passed verbatim to iadp, e.g. --options="-q 16 -c 0"; '
            'see iadp --help for the full list of supported flags'
        ),
    )
    args = parser.parse_args()

    created = []
    for file_name in args.input_files:
        base, base_path = create_notebook_directory(file_name, args.dir, args.sdir)
        if not base_path:
            continue

        txt_path = base_path + '.txt'
        rxt_path = base_path + '.rxt'
        grid_path = base_path + '.grid'

        cache_valid = (
            os.path.exists(txt_path) and os.path.getsize(txt_path) > 0
            and os.path.exists(grid_path) and os.path.getsize(grid_path) > 0
        )
        if args.force or not cache_valid:
            print('inverting: %s' % rxt_path)
            if not run_iadp(rxt_path, txt_path, args.options):
                print('Sorry, inversion failed for %s' % rxt_path)
                continue
        else:
            print('Using cached results (--force to redo): %s' % txt_path)

        try:
            data = load_txt_data(txt_path, rxt_path)
        except Exception as exc:  # pylint: disable=broad-except
            print('Error reading results for %s: %s' % (rxt_path, exc))
            continue

        lam     = data['lam']
        mr      = data['mr']
        cr      = data['cr']
        mt      = data['mt']
        ct      = data['ct']
        mua     = data['mua']
        musp    = data['musp']
        g       = data['g']
        mus     = data['mus']
        b       = data['b']
        a       = data['a']
        success = data['success']

        rt_graph   = plot_rt(lam, mr, mt, base_path)
        r_graph    = plot_r(lam, mr, cr, success, base_path)
        t_graph    = plot_t(lam, mt, ct, success, base_path)
        mua_graph  = plot_mua(lam, mua, success, base_path)
        musp_graph = plot_musp(lam, musp, success, base_path, fit=args.fit)
        mus_graph  = plot_mus(lam, mus, success, base_path, fit=args.fit)
        a_graph    = plot_a(lam, a, success, base_path)
        b_graph    = plot_b(lam, b, success, base_path)
        g_graph    = plot_g(lam, g, success, base_path)
        grid_graph = plot_grid(mr, cr, mt, ct, success, base_path)

        nb = new_notebook()
        nb.metadata['kernelspec'] = {
            'display_name': 'Python 3',
            'language': 'python',
            'name': 'python3',
        }

        append_header(nb, rxt_path)
        append_graph_cell(nb, '## Reflection', r_graph)
        append_graph_cell(nb, '## Transmission', t_graph)
        append_graph_cell(nb, '## Absorption Coefficient', mua_graph)
        append_graph_cell(nb, '## Reduced Scattering Coefficient', musp_graph)
        append_graph_cell(nb, '## Single Scattering Albedo', a_graph)
        append_graph_cell(nb, '## Optical Thickness', b_graph)
        append_graph_cell(nb, '## Scattering Anisotropy', g_graph)
        append_graph_cell(nb, '## Scattering Coefficient', mus_graph)
        append_graph_cell(nb, '## Original Measurements', rt_graph)
        append_graph_cell(nb, '## Grid Graph', grid_graph)

        nb.cells.append(new_markdown_cell('## Input file\n'))
        append_file_cell(nb, '# input file', base + '.rxt')

        ipynb_path = base_path + '.ipynb'
        with open(ipynb_path, 'w', encoding='utf-8') as f:
            nbformat.write(nb, f)

        created.append(ipynb_path)
        print('Created: %s' % ipynb_path)

    if len(created) > 1:
        print('\n%d notebooks created.' % len(created))


if __name__ == '__main__':
    main()
