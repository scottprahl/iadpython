#!/usr/bin/env python3

# pylint: disable=invalid-name
# pylint: disable=too-many-locals
# pylint: disable=consider-using-f-string

"""Jupyter notebook generator for IAD analysis using iadpython.

Replaces the old ``iadplus`` wrapper that called the compiled C ``iad``
binary.  All inversion is done by ``iadp`` (``iadcommand.py``), which
supports the full set of command-line options.

Usage::

    python iadpython/iadplus file.rxt [file2.rxt ...]
    python iadpython/iadplus --fit file.rxt
    python iadpython/iadplus --force file1.rxt file2.rxt
    python iadpython/iadplus --options="-q 16 -c 0" file.rxt
"""

import argparse
import os
import shlex
import shutil
import subprocess
import sys
import urllib.parse
from datetime import datetime

import numpy as np
import matplotlib.pyplot as plt
import nbformat
from nbformat.v4 import new_notebook, new_code_cell, new_markdown_cell
from scipy.optimize import curve_fit

import iadpython

skyblue = '#00bfff'
ocean = '#009dc4'
azure = '#1520a6'


# ---------------------------------------------------------------------------
# Inversion via iadp subprocess
# ---------------------------------------------------------------------------

def run_iadp(rxt_path, txt_path, options_str):
    """Run ``iadcommand.py`` on *rxt_path*, writing results to *txt_path*.

    *options_str* is a string of extra flags forwarded verbatim to ``iadp``
    (e.g. ``"-q 16 -c 0"``).  Returns True on success.
    """
    cmd = [sys.executable, '-m', 'iadpython.iadcommand']
    if options_str:
        cmd += shlex.split(options_str)
    cmd += ['-J', '-o', txt_path, rxt_path]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        msg = (result.stderr or result.stdout).strip()
        print('iadp failed: %s' % msg)
        return False
    return True


def parse_iadp_txt(txt_path):
    """Read an ``iadp`` ``.txt`` output file and return arrays.

    The ``iadp`` format has three ``#``-prefixed header lines followed by
    tab-separated data columns::

        lam  mr  cr  mt  ct  mua  musp  g

    Returns ``(lam, mr, cr, mt, ct, mua, musp, g, success)`` as numpy arrays.
    ``success`` is True for rows where *mua* and *musp* are finite and ≥ 0.
    """
    arr = np.atleast_2d(np.loadtxt(txt_path, comments='#', delimiter='\t'))
    cols = arr.T
    lam  = cols[0]
    mr   = cols[1]
    cr   = cols[2]
    mt   = cols[3]
    ct   = cols[4]
    mua  = cols[5]
    musp = cols[6]
    g    = cols[7]
    success = np.isfinite(mua) & np.isfinite(musp) & (mua >= 0) & (musp >= 0)
    return lam, mr, cr, mt, ct, mua, musp, g, success


def load_txt_data(txt_path, rxt_path=None):
    """Read ``iadp`` output and return a results dict.

    *rxt_path* is used to look up the sample thickness *d* (needed to
    compute optical thickness *b*).  If omitted or unreadable, ``d = 1.0``
    is used as a fallback.

    Returns a dict with keys: lam, mr, cr, mt, ct, mua, musp, g, mus, b, a,
    success, d.
    """
    lam, mr, cr, mt, ct, mua, musp, g, success = parse_iadp_txt(txt_path)

    d = 1.0
    if rxt_path and os.path.exists(rxt_path):
        try:
            rxt_exp = iadpython.read_rxt(rxt_path)
            d_val = rxt_exp.sample.d
            d = float(d_val) if np.isscalar(d_val) else float(np.atleast_1d(d_val).flat[0])
        except Exception:  # pylint: disable=broad-except
            pass

    with np.errstate(invalid='ignore', divide='ignore'):
        mus = np.where(g < 1, musp / (1.0 - g), np.nan)
        denom = mua + mus
        a = np.where(denom > 0, mus / denom, np.nan)
        b = denom * d

    return {
        'lam': lam, 'mr': mr, 'cr': cr,
        'mt': mt,   'ct': ct,
        'mua': mua, 'musp': musp, 'g': g,
        'mus': mus, 'b': b, 'a': a,
        'success': success, 'd': d,
    }


# ---------------------------------------------------------------------------
# Plot helpers
# ---------------------------------------------------------------------------

def add_x_label(lambda0):
    """Add an appropriate x-axis label based on the wavelength range."""
    if lambda0[0] > 300:
        plt.xlabel('Wavelength (nm)', fontsize=12)
    else:
        plt.xlabel('Measurement Number', fontsize=12)


def plot_good(x, y, success, big_points=False):
    """Plot only the successful points."""
    size, fc = (7, 'none') if big_points else (2, 'blue')
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')
    plt.grid(True)


def plot_good_and_bad(x, y, success, big_points=False):
    """Plot successful points in blue and failures as red crosses."""
    size, fc = (7, 'none') if big_points else (2, 'blue')
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')
    if any(~success):
        plt.plot(x[~success], y[~success], 'xr', label='failed')
        plt.legend()
    plt.grid(True)


def plot_gridlines(filename_base):
    """Overlay the `.grid` lines generated by `iadcommand.py -J`."""
    gridname = filename_base + '.grid'

    if not os.path.exists(gridname) or os.path.getsize(gridname) == 0:
        print('no grid file "%s"' % gridname)
        return

    try:
        a, b, _g, mr, mt = np.loadtxt(gridname, skiprows=2, delimiter=',').T
    except Exception as exc:  # pylint: disable=broad-except
        print('could not read grid file "%s": %s' % (gridname, exc))
        return

    n_points = len(a)
    for aa in sorted(set(a)):
        r = [mr[i] for i in range(n_points) if a[i] == aa]
        t = [mt[i] for i in range(n_points) if a[i] == aa]
        if not r:
            continue
        plt.plot(r, t, 'k', lw=0.5)
        label = "a'=%4.2f" % aa if aa == 0 else '%4.2f' % aa
        plt.text(r[-1], t[-1] - 0.01, label, ha='center', va='top')

    for bb in sorted(set(b)):
        r = [mr[i] for i in range(n_points) if b[i] == bb]
        t = [mt[i] for i in range(n_points) if b[i] == bb]
        if not r:
            continue
        plt.plot(r, t, 'k', lw=0.5)
        plt.text(r[-1], t[-1], "b'=%g" % bb)

    r_a1 = [mr[i] for i in range(n_points) if a[i] == 1]
    t_a1 = [mt[i] for i in range(n_points) if a[i] == 1]
    r_bmax = [mr[i] for i in range(n_points) if b[i] == max(b)]
    t_bmax = [mt[i] for i in range(n_points) if b[i] == max(b)]
    r_a0 = [mr[i] for i in range(n_points) if a[i] == 0]
    t_a0 = [mt[i] for i in range(n_points) if a[i] == 0]
    if r_a1 and r_bmax and r_a0:
        poly_r = r_a1 + r_bmax[::-1] + r_a0[::-1]
        poly_t = t_a1 + t_bmax[::-1] + t_a0[::-1]
        poly = plt.Polygon(np.array([poly_r, poly_t]).T, closed=True, facecolor=ocean, edgecolor='none')
        plt.gca().add_patch(poly)
        plt.plot(poly_r, poly_t, 'k', lw=0.5)

    plt.grid(False)


def plot_grid(mr, cr, mt, ct, success, filename_base):
    """Plot measured vs. calculated M_R and M_T in the valid solution triangle."""
    out_filename = filename_base + '-grid.svg'
    plt.figure(figsize=(8, 8))
    plt.gca().set_aspect(1)
    plt.xlim(-0.05, 1.05)
    plt.ylim(-0.05, 1.05)
    plt.xticks(fontsize=12)
    plt.yticks(fontsize=12)
    plot_good(cr, ct, success, True)
    if any(success):
        plt.plot(mr[success], mt[success], 'o', markersize=2, color=azure, label='measured')
    if any(~success):
        plt.plot(mr[~success], mt[~success], 'x', markersize=5, color='red', label='failed')
    poly = plt.Polygon([[0, 0], [0, 1], [1, 0]], closed=True, facecolor=skyblue, edgecolor='none', alpha=1)
    plt.gca().add_patch(poly)
    plot_gridlines(filename_base)
    plt.xlabel('$M_R$ (Normalized Reflectance)', fontsize=12)
    plt.ylabel('$M_T$ (Normalized Transmittance)', fontsize=12)
    plt.legend()
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)


def plot_rt(lam, mr, mt, filename_base):
    """Plot measured R, T, and their sum vs. wavelength."""
    out_filename = filename_base + '-RTU.svg'
    plt.figure(figsize=(8, 4.5))
    plt.plot(lam, mr, 'ob', markersize=2, label='$M_R$')
    plt.plot(lam, mt, 'or', markersize=2, label='$M_T$')
    plt.plot(lam, mr + mt, 'ok', markersize=2, label='$M_R + M_T$')
    plt.ylabel('Measurement')
    add_x_label(lam)
    plt.legend()
    plt.grid(True)
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)


def plot_r(lam, mr, cr, success, filename_base):
    """Plot measured and fitted reflectance vs. wavelength."""
    out_filename = filename_base + '-R.svg'
    plt.figure(figsize=(8, 4.5))
    plot_good_and_bad(lam, cr, success, True)
    plt.plot(lam, mr, 'ok', markersize=2, label='measured')
    add_x_label(lam)
    plt.ylabel('$M_R$ (Normalized Reflectance)', fontsize=12)
    plt.legend()
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)


