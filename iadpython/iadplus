def plot_mua(lam, mua, success, filename_base):
    """Plot absorption coefficient vs. wavelength."""
    out_filename = filename_base + '-mua.svg'
    plt.figure(figsize=(8, 4.5))
    plot_good_and_bad(lam, mua, success)
    add_x_label(lam)
    plt.ylabel('Absorption Coefficient (mm\u207b\xb9)')
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)


def scattering_model(x, a, b):
    """Power-law scattering model: a * (x/1000)^(-b)."""
    return a * (x / 1000) ** (-b)


def _fit_and_plot_scattering(lam, values, success, label):
    """Overlay a power-law fit on the current axes when wavelength data is present."""
    if lam[0] > 300 and any(success):
        popt, _ = curve_fit(scattering_model, lam[success], values[success])
        a_opt, b_opt = popt
        lamb = np.linspace(min(lam), max(lam))
        fn_str = '%s=%g * (lam_nm/1000)**(-%g)' % (label, a_opt, b_opt)
        plt.plot(lamb, scattering_model(lamb, a_opt, b_opt), label=fn_str)
        plt.legend()


def plot_musp(lam, musp, success, filename_base, fit=False):
    """Plot reduced scattering coefficient vs. wavelength."""
    out_filename = filename_base + '-musp.svg'
    plt.figure(figsize=(8, 4.5))
    plot_good_and_bad(lam, musp, success)
    if fit:
        _fit_and_plot_scattering(lam, musp, success, 'musp')
    plt.ylabel('Reduced Scattering Coefficient (mm\u207b\xb9)')
    add_x_label(lam)
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)


